# KMTI Workstation Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# .env is gitignored and must NEVER be committed to source control.

DB_HOST=192.168.200.105
DB_NAME=kmtiworkstation
DB_USER=your_db_user
DB_PASS=your_db_password

# JWT — generate a strong random string (min 32 chars) and keep it secret
# Example: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_A_RANDOM_32_CHAR_STRING
